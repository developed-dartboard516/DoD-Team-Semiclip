
SET "MSBuilder=%ProgramFiles%/Microsoft Visual Studio/18/Insiders/MSBuild/Current/Bin/MSBuild.exe"
SET "Proj=semiclip"

"%MSBuilder%" "microsoft/%Proj%.vcxproj" "/p:configuration=Release"            "/p:platform=Win32"
"%MSBuilder%" "microsoft/%Proj%.vcxproj" "/p:configuration=Release.AVX"        "/p:platform=Win32"
"%MSBuilder%" "microsoft/%Proj%.vcxproj" "/p:configuration=Release.AVX2"       "/p:platform=Win32"
"%MSBuilder%" "microsoft/%Proj%.vcxproj" "/p:configuration=Release.WinXP"      "/p:platform=Win32"
"%MSBuilder%" "microsoft/%Proj%.vcxproj" "/p:configuration=Release.WinXP.AVX2" "/p:platform=Win32"

RMDIR /Q /S "microsoft/.vs"
RMDIR /Q /S "microsoft/%Proj%"

RMDIR /Q /S "microsoft/Release/%Proj%.tlog"
RMDIR /Q /S "microsoft/Release.AVX/%Proj%.tlog"
RMDIR /Q /S "microsoft/Release.AVX2/%Proj%.tlog"
RMDIR /Q /S "microsoft/Release.WinXP/%Proj%.tlog"
RMDIR /Q /S "microsoft/Release.WinXP.AVX2/%Proj%.tlog"

